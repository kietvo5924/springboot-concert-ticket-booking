                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "bookings"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                }
                            ]
                        },
                        "description": "GHI CHÚ:\nAPI dành cho Admin. Lấy danh sách toàn bộ các đơn hàng trong hệ thống (có hỗ trợ phân trang)."
                    }
                },
                {
                    "name": "Get Ticket Availability",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/admin/tickets/availability",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "tickets",
                                "availability"
                            ]
                        },
                        "description": "GHI CHÚ:\nAPI dành cho Admin. Xem báo cáo tổng quan về số lượng vé ban đầu (initial quantity) và số lượng vé còn lại (remaining quantity) của từng loại vé."
                    }
                },
                {
                    "name": "Update Order Status",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/admin/bookings/1/status",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "bookings",
                                "1",
                                "status"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"COMPLETED\"\n}"
                        },
                        "description": "GHI CHÚ:\nAPI dành cho Admin để can thiệp và cập nhật trạng thái đơn hàng (ví dụ đổi từ PENDING sang COMPLETED hoặc CANCELLED)."
                    }
                },
                {
                    "name": "Get DLQ Messages",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/admin/dlq",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "dlq"
                            ]
                        },
                        "description": "GHI CHÚ:\nAPI dành cho Admin. Xem danh sách các tin nhắn xử lý lỗi đã bị đẩy vào hàng đợi Dead Letter Queue (DLQ)."
                    },
                    "response": []
                },
                {
                    "name": "Retry DLQ Message",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/admin/dlq/1/retry",
                            "protocol": "http",
                            "host": [
                                "localhost"
