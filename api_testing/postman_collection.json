{
    "info": {
        "name": "Concert Ticket Booking",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Customer APIs",
            "item": [
                {
                    "name": "Submit Booking Request",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/bookings",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "bookings"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"userId\": 1,\n  \"concertId\": 1,\n  \"ticketCategoryId\": 1,\n  \"voucherId\": null,\n  \"requestId\": \"req-uuid-12345\"\n}"
                        },
                        "description": "GHI CHÚ:\nAPI này cố định `requestId` để test cơ chế Idempotency. Để thấy rõ kết quả, hãy dùng tính năng **Run Collection (Postman Runner)** với số lượng vòng lặp (Iterations) lớn hơn 1.\n- Request đầu tiên thành công (202).\n- Các request sau bị chặn lại (409 Conflict).\n- Nếu chạy quá 5 req/s sẽ bị chặn bởi Rate Limiter (429 Too Many Requests)."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 202, 409 or 429 (Expected behavior)\", function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([202, 409, 429]);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },
                {
                    "name": "Submit Booking Request (Spam Test)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/bookings",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "bookings"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"userId\": 1,\n  \"concertId\": 1,\n  \"ticketCategoryId\": 1,\n  \"voucherId\": null,\n  \"requestId\": \"{{randomReqId}}\"\n}"
                        },
                        "description": "GHI CHÚ:\nAPI này dùng để test Load / Spam request. Sử dụng tính năng Pre-request script để tự động sinh ra UUID ngẫu nhiên cho mỗi lần lặp, nhằm vượt qua lớp bảo vệ Idempotency, giúp bạn test chính xác tính năng Rate Limiter (quá 5 req/s sẽ bị chặn 429) và tính toàn vẹn của hệ thống (hết vé sẽ báo 400 Sold Out)."
                    },
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.variables.set('randomReqId', pm.variables.replaceIn('{{$guid}}'));"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },
                {
                    "name": "Get All Concerts",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/concerts",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "concerts"
                            ]
                        },
                        "description": "GHI CHÚ:\nLấy danh sách tất cả các buổi biểu diễn (Concerts) đang có trên hệ thống."
                    }
                },
                {
                    "name": "Get Ticket Categories by Concert ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/concerts/1/categories",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "concerts",
                                "1",
                                "categories"
                            ]
                        },
                        "description": "GHI CHÚ:\nLấy danh sách các loại vé (VD: VIP, STANDARD), thông tin giá vé và số lượng vé còn lại của concert mang id = 1."
                    }
                },
                {
                    "name": "Get Booking Status",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/bookings/req-uuid-12345",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "bookings",
                                "req-uuid-12345"
                            ]
                        },
                        "description": "GHI CHÚ:\nKiểm tra trạng thái của một đơn hàng (PENDING, COMPLETED, FAILED) thông qua mã requestId. Dùng để làm polling checking sau khi đã submit booking."
                    }
                },
                {
                    "name": "Pay Order",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/bookings/req-uuid-12345/pay",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "bookings",
                                "req-uuid-12345",
                                "pay"
                            ]
                        },
                        "description": "GHI CHÚ:\nMô phỏng hành động khách hàng thanh toán thành công cho đơn đặt vé."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Admin APIs",
            "item": [
